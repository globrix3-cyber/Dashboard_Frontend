# ─────────────────────────────────────────────
#  Globrix Frontend — Environment Variables
# ─────────────────────────────────────────────

# Leave EMPTY in development.
# Vite's dev-server proxy (vite.config.js) forwards /api → http://localhost:8000
# so no URL is needed here.
#
# In production, set this to your deployed API origin, e.g.:
#   VITE_API_URL=https://api.globrix.com
VITE_API_URL=